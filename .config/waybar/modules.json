{
    "output": "DP-1",
    "hyprland/workspaces": {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "persistent-workspaces": {
            "DP-1":     [1, 2, 3, 4, 5],
            "HDMI-A-2": [6, 7, 8]
        }
    },

    "hyprland/window": {
        "rewrite": {
            "(.*) - Firefox": "$1",
            "(.*) - kitty": "$1"
        },
        "separate-outputs": true
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "󰥔 {0:%H:%M}",
        "format-alt": "󰥔 {0:%H:%M}   {0:%d-%m-%Y}"
    },

    "network": {
        "format-ethernet": "  {bandwidthDownBytes}  {bandwidthUpBytes}",
        "format-disconnected": "󰲛 Disconnected",
        "tooltip-format-ethernet": "{ifname} ({ipaddr}/{cidr})",
        "max-length": 50,
        "interval": 2
    },

    "cpu": {
        "format": "󰍛 {usage}%",
        "interval": 2
    },

    "memory": {
        "format": "󰾆 {percentage}%",
        "interval": 2
    },

    "custom/gpu-usage": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu --format=csv,noheader,nounits | awk -F', ' '{printf \"󰾲 %s%% %s°C\", $1, $2}'",
        "interval": 2,
        "exec-if": "which nvidia-smi"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 Muted",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    }
}
